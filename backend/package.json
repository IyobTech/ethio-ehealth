{
  "name": "ethio-ehealth-backend",
  "version": "1.0.0",
  "description": "Ethio E-Health Platform Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "express": "^4.18.2",
    "typescript": "^5.3.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "joi": "^17.11.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "express-async-errors": "^3.1.1",
    "socket.io": "^4.7.2",
    "nodemailer": "^6.9.7",
    "twilio": "^4.10.0",
    "axios": "^1.6.5",
    "openai": "^4.26.0",
    "multer": "^1.4.5-lts.1",
    "firebase-admin": "^12.0.0",
    "cloudinary": "^1.40.0",
    "express-rate-limit": "^7.1.5",
    "uuid": "^9.0.1",
    "node-cron": "^3.0.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.14",
    "@types/jest": "^29.5.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0"
  }
}
